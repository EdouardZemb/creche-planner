{
  "name": "@creche-planner/svc-tarification",
  "version": "0.13.0",
  "private": true,
  "nx": {
    "name": "svc-tarification",
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "command": "webpack-cli build",
          "args": [
            "--config-node-env=production"
          ],
          "cwd": "apps/svc-tarification"
        },
        "configurations": {
          "development": {
            "args": [
              "--config-node-env=development"
            ]
          }
        }
      },
      "prune-lockfile": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "executor": "@nx/js:prune-lockfile",
        "outputs": [
          "{workspaceRoot}/apps/svc-tarification/dist/package.json",
          "{workspaceRoot}/apps/svc-tarification/dist/pnpm-lock.yaml"
        ],
        "options": {
          "buildTarget": "build"
        }
      },
      "copy-workspace-modules": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "outputs": [
          "{workspaceRoot}/apps/svc-tarification/dist/workspace_modules"
        ],
        "executor": "@nx/js:copy-workspace-modules",
        "options": {
          "buildTarget": "build"
        }
      },
      "prune": {
        "dependsOn": [
          "prune-lockfile",
          "copy-workspace-modules"
        ],
        "executor": "nx:noop"
      },
      "test": {
        "dependsOn": [
          "build"
        ]
      },
      "serve": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build"
        ],
        "options": {
          "buildTarget": "svc-tarification:build",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": {
            "buildTarget": "svc-tarification:build:development"
          },
          "production": {
            "buildTarget": "svc-tarification:build:production"
          }
        }
      }
    },
    "tags": [
      "type:app",
      "context:tarification"
    ]
  },
  "dependencies": {
    "@creche-planner/tarification-domain": "workspace:*",
    "@creche-planner/contracts-foyer": "workspace:*",
    "@creche-planner/contracts-referentiel": "workspace:*",
    "@creche-planner/contracts-planification": "workspace:*",
    "@creche-planner/shared-kernel": "workspace:*",
    "@creche-planner/nest-commons": "workspace:*",
    "@creche-planner/observability": "workspace:*",
    "@creche-planner/resilience": "workspace:*",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/terminus": "^11.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "drizzle-orm": "^0.45.2",
    "nats": "^2.29.3",
    "nestjs-pino": "^4.6.1",
    "postgres": "^3.4.9",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "tslib": "^2.3.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.27",
    "@pact-foundation/pact": "^17.0.1",
    "drizzle-kit": "^0.31.10"
  }
}
