{
  "name": "@creche-planner/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "nx": {
    "name": "web",
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "outputs": [
          "{workspaceRoot}/dist/apps/web"
        ],
        "options": {
          "command": "vite build",
          "cwd": "apps/web"
        }
      },
      "dev": {
        "continuous": true,
        "executor": "nx:run-commands",
        "options": {
          "command": "vite --port 4200 --host",
          "cwd": "apps/web"
        }
      },
      "serve": {
        "continuous": true,
        "executor": "nx:run-commands",
        "options": {
          "command": "vite --port 4200 --host",
          "cwd": "apps/web"
        }
      },
      "preview": {
        "continuous": true,
        "executor": "nx:run-commands",
        "options": {
          "command": "vite preview --port 4200",
          "cwd": "apps/web"
        }
      },
      "typecheck": {
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "tsc --noEmit -p tsconfig.app.json",
            "tsc --noEmit -p tsconfig.spec.json"
          ],
          "parallel": false,
          "cwd": "apps/web"
        }
      },
      "generate-types": {
        "executor": "nx:run-commands",
        "outputs": [
          "{projectRoot}/src/api/openapi-types.gen.ts"
        ],
        "options": {
          "command": "node ../../scripts/generate-openapi-types.mjs",
          "cwd": "apps/web"
        }
      },
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "vitest run --passWithNoTests",
          "cwd": "apps/web"
        }
      },
      "e2e": {
        "executor": "nx:run-commands",
        "dependsOn": [
          "build"
        ],
        "options": {
          "command": "playwright test",
          "cwd": "apps/web"
        }
      },
      "e2e-stack": {
        "executor": "nx:run-commands",
        "options": {
          "command": "node ../../scripts/e2e-stack.mjs",
          "cwd": "apps/web"
        }
      }
    },
    "tags": [
      "type:app",
      "context:web"
    ]
  },
  "dependencies": {
    "@creche-planner/contracts-kernel": "workspace:*",
    "@fullcalendar/core": "~6.1.21",
    "@fullcalendar/daygrid": "~6.1.21",
    "@fullcalendar/interaction": "~6.1.21",
    "@fullcalendar/react": "~6.1.21",
    "@fullcalendar/timegrid": "~6.1.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^6.28.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^26.0.0",
    "vite-plugin-pwa": "^1.3.0"
  }
}
