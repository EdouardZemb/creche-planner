{
  "consumer": {
    "name": "api-gateway"
  },
  "interactions": [
    {
      "description": "une lecture de la liste des établissements",
      "providerStates": [
        {
          "name": "des établissements destinataires existent"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/api/etablissements"
      },
      "response": {
        "body": [
          {
            "actif": true,
            "cle": "CRECHE_HIRONDELLES",
            "emailService": "contact-creche@example.org",
            "libelle": "Crèche Les Hirondelles",
            "preavisRegle": {
              "type": "JOURS_OUVRES"
            }
          }
        ],
        "headers": {
          "Content-Type": "application/json; charset=utf-8"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$[*].actif": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].cle": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].emailService": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].libelle": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].preavisRegle.type": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          },
          "header": {},
          "status": {}
        },
        "status": 200
      }
    },
    {
      "description": "une mise à jour de l’établissement crèche",
      "providerStates": [
        {
          "name": "un établissement crèche modifiable existe"
        }
      ],
      "request": {
        "body": {
          "emailService": "nouvelle@example.org",
          "preavisRegle": {
            "type": "JOURS_OUVRES",
            "valeur": 3
          }
        },
        "headers": {
          "Content-Type": "application/json; charset=utf-8"
        },
        "method": "PUT",
        "path": "/api/etablissements/CRECHE_HIRONDELLES"
      },
      "response": {
        "body": {
          "actif": true,
          "cle": "CRECHE_HIRONDELLES",
          "emailService": "nouvelle@example.org",
          "libelle": "Crèche Les Hirondelles",
          "preavisRegle": {
            "type": "JOURS_OUVRES",
            "valeur": 3
          }
        },
        "headers": {
          "Content-Type": "application/json; charset=utf-8"
        },
        "matchingRules": {
          "body": {
            "$.actif": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.cle": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.emailService": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.libelle": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.preavisRegle.type": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.preavisRegle.valeur": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            }
          },
          "header": {},
          "status": {}
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "13.2.0"
    },
    "pactRust": {
      "ffi": "0.4.22",
      "models": "1.2.3"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "svc-notifications"
  }
}