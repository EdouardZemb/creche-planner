{
  "name": "@creche-planner/planification-domain",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@creche-planner/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "nx": {
    "name": "planification-domain",
    "tags": [
      "type:domain",
      "context:planification"
    ],
    "targets": {
      "mutation": {
        "executor": "nx:run-commands",
        "options": {
          "command": "stryker run",
          "cwd": "libs/planification/domain"
        },
        "dependsOn": [
          "^build"
        ],
        "cache": false
      }
    }
  },
  "dependencies": {
    "@creche-planner/shared-kernel": "workspace:*",
    "tslib": "^2.3.0"
  }
}
