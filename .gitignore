# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
test-output

# Dumps de sauvegarde PostgreSQL — ne JAMAIS versionner (données + volumineux)
backups

# Playwright (E2E) artefacts
test-results
playwright-report
.playwright

# Baseline de couverture (AQ-06) — téléchargée/produite par la CI, jamais versionnée
.coverage-baseline
coverage-baseline

# Mutation testing (AQ-13) — bac à sable Stryker (les rapports vont dans test-output)
.stryker-tmp

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

