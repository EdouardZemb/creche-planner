{
  "id": null,
  "uid": "creche-postgres",
  "title": "Creche Planner — Bases Postgres",
  "description": "Santé des 4 bases Postgres (referentiel, foyer, planification, tarification) via postgres-exporter (Phase 13c) : disponibilité, connexions, transactions, latence, cache, deadlocks, taille.",
  "tags": ["creche-planner", "postgres", "database"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": {
          "type": "yesoreyeram-infinity-datasource",
          "uid": "infinity-github-deploys"
        },
        "enable": true,
        "iconColor": "purple",
        "name": "Déploiements (prod)",
        "target": {
          "refId": "Deploiements",
          "type": "json",
          "source": "url",
          "format": "table",
          "parser": "backend",
          "url": "https://api.github.com/repos/EdouardZemb/creche-planner/deployments?environment=production&per_page=30",
          "url_options": { "method": "GET" },
          "root_selector": "",
          "columns": [
            { "selector": "created_at", "text": "time", "type": "timestamp" },
            { "selector": "description", "text": "text", "type": "string" },
            { "selector": "environment", "text": "tags", "type": "string" }
          ]
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Bases Postgres UP",
      "description": "sum(pg_up) — nombre de bases joignables par leur exporter (doit valoir 4).",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 4 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(pg_up)"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Disponibilité par base (pg_up)",
      "description": "pg_up par base — 1 = DB joignable depuis l'exporter, 0 = injoignable (alerte PostgresDown).",
      "gridPos": { "h": 4, "w": 18, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 20,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "pg_up",
          "legendFormat": "{{base}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Connexions actives par base",
      "description": "pg_stat_database_numbackends agrégé par base — nombre de backends connectés.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (base) (pg_stat_database_numbackends)",
          "legendFormat": "{{base}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "% des connexions autorisées utilisées",
      "description": "connexions / max_connections par base. Alerte PostgresTooManyConnections au-delà de 80 %.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "red", "value": 0.95 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (base) (pg_stat_database_numbackends) / max by (base) (pg_settings_max_connections)",
          "legendFormat": "{{base}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Transactions validées / s (commits)",
      "description": "rate(pg_stat_database_xact_commit) par base — débit de transactions validées.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (base) (rate(pg_stat_database_xact_commit{datname=~\"referentiel|foyer|planification|tarification\"}[$__rate_interval]))",
          "legendFormat": "{{base}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Rollbacks / s",
      "description": "rate(pg_stat_database_xact_rollback) par base — transactions annulées (anomalie si soutenu).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (base) (rate(pg_stat_database_xact_rollback{datname=~\"referentiel|foyer|planification|tarification\"}[$__rate_interval]))",
          "legendFormat": "{{base}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Latence — durée max de transaction par base",
      "description": "max(pg_stat_activity_max_tx_duration) par base — transaction la plus longue en cours. Alerte au-delà de 5 min.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "max by (base) (pg_stat_activity_max_tx_duration)",
          "legendFormat": "{{base}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Taux de cache (buffer hit ratio)",
      "description": "blks_hit / (blks_hit + blks_read) par base — proche de 1 = lectures servies par le cache.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "min"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (base) (rate(pg_stat_database_blks_hit{datname=~\"referentiel|foyer|planification|tarification\"}[$__rate_interval])) / clamp_min(sum by (base) (rate(pg_stat_database_blks_hit{datname=~\"referentiel|foyer|planification|tarification\"}[$__rate_interval])) + sum by (base) (rate(pg_stat_database_blks_read{datname=~\"referentiel|foyer|planification|tarification\"}[$__rate_interval])), 0.001)",
          "legendFormat": "{{base}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Deadlocks / s",
      "description": "rate(pg_stat_database_deadlocks) par base — > 0 = transactions mutuellement bloquées (alerte PostgresDeadlocks).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (base) (rate(pg_stat_database_deadlocks{datname=~\"referentiel|foyer|planification|tarification\"}[$__rate_interval]))",
          "legendFormat": "{{base}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Taille des bases",
      "description": "pg_database_size_bytes par base — croissance du volume de données.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "max by (base) (pg_database_size_bytes{datname=~\"referentiel|foyer|planification|tarification\"})",
          "legendFormat": "{{base}}"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "label": "Prometheus"
      }
    ]
  }
}
