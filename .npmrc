# Linker isolé (par défaut pnpm) : requis par Nx (qui résout des deps dans ses
# propres node_modules imbriqués) et par les bindings natifs optionnels.
# Le scan ESLint des node_modules imbriqués est neutralisé via ignorePatterns
# dans chaque .eslintrc.json de projet.
strict-peer-dependencies=false
auto-install-peers=true
